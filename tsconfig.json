{
  "include": [
    "./src/**/*"
  ],
  "exclude": [
    "./node_modules",
  ],
  "ts-node": {
    "files": true,
    "swc": true
  },
  "compilerOptions": {
    "target": "ES2015",
    "module": "commonjs",
    "resolveJsonModule": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true                                 /* Skip type checking all .d.ts files. */
  }
}
